import tkinter as tk
from tkinter import filedialog, messagebox
from PIL import Image, ImageTk
import qrcode
import cv2
import os
import sys
import numpy as np
import webbrowser  
if getattr(sys, 'frozen', False):
    script_dir = os.path.dirname(sys.executable)
else:
    script_dir = os.path.dirname(os.path.abspath(__file__))
def generate_qr():
    data = entry.get().strip()
    if not data:
        messagebox.showwarning("Input Error", "Please enter data to generate QR code.")
        return
    qr = qrcode.QRCode(
        version=None,
        error_correction=qrcode.constants.ERROR_CORRECT_L,
        box_size=10,
        border=4,
    )
    qr.add_data(data)
    qr.make(fit=True)
    img = qr.make_image(fill_color="black", back_color="white")
    save_path = os.path.join(script_dir, "qr_generated.png")
    img.save(save_path)
    qr_img = Image.open(save_path)
    qr_img = qr_img.resize((200, 200))
    qr_tk = ImageTk.PhotoImage(qr_img)
    qr_label.config(image=qr_tk)
    qr_label.image = qr_tk
    messagebox.showinfo("Saved", f"QR code saved as:\n{save_path}")
def scan_qr():
    path = filedialog.askopenfilename(filetypes=[("Image Files", "*.png *.jpg *.jpeg")])
    if not path:
        return
    try:
        img = cv2.imdecode(np.fromfile(path, dtype=np.uint8), cv2.IMREAD_COLOR)
    except:
        img = cv2.imread(path)
    if img is None:
        messagebox.showerror("Error", "Failed to load image.\nTry another file.")
        return
    detector = cv2.QRCodeDetector()
    data, bbox, _ = detector.detectAndDecode(img)
    if data:
        data = data.strip()   
        entry.delete(0, tk.END)
        entry.insert(0, data)
        opened = False
        if data.startswith("http://") or data.startswith("https://"):
            webbrowser.open(data)
            opened = True
        elif "." in data and " " not in data:
            webbrowser.open("https://" + data)
            opened = True
        elif os.path.exists(data):
            try:
                os.startfile(data)
            except:
                import subprocess
                subprocess.Popen(data, shell=True)
            opened = True
        if opened:
            messagebox.showinfo("Opened", f"Opened: {data}")
        else:
            messagebox.showinfo("QR Code Content", f"Scanned Data: {data}")
    else:
        messagebox.showwarning("Scan Failed", "No QR code found in the image.")
def scan_qr_live():
    cap = cv2.VideoCapture(0)
    detector = cv2.QRCodeDetector()
    print("[INFO] Press 'q' to quit")
    while True:
        ret, frame = cap.read()
        if not ret:
            break
        data, bbox, _ = detector.detectAndDecode(frame)
        if bbox is not None:
            pts = bbox.astype(int).reshape(-1, 2)
            for i in range(len(pts)):
                cv2.line(frame, tuple(pts[i]), tuple(pts[(i+1) % len(pts)]), (0, 255, 0), 2)
        if data:
            data = data.strip()   
            cv2.putText(frame, data, (50, 50),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.7, (255, 0, 0), 2)
            entry.delete(0, tk.END)
            entry.insert(0, data)
            opened = False
            if data.startswith("http://") or data.startswith("https://"):
                webbrowser.open(data)
                opened = True

            elif "." in data and " " not in data:
                webbrowser.open("https://" + data)
                opened = True
            elif os.path.exists(data):
                try:
                    os.startfile(data)
                except:
                    import subprocess
                    subprocess.Popen(data, shell=True)
                opened = True
            if opened:
                messagebox.showinfo("Opened", f"Opened: {data}")
                break 
            else:
                messagebox.showinfo("QR Content", f"Scanned Data: {data}")
        cv2.imshow("Live QR Scanner", frame)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break
    cap.release()
    cv2.destroyAllWindows()
root = tk.Tk()
root.title("QR Code Generator & Scanner")
root.geometry("400x550")
root.configure(bg="white")
tk.Label(root, text="Enter text to generate QR", font=("Arial", 14), bg="white").pack(pady=10)
entry = tk.Entry(root, font=("Arial", 12), width=30)
entry.pack(pady=5)
tk.Button(root, text="Generate QR Code", command=generate_qr,
          font=("Arial", 12), bg="green", fg="white").pack(pady=10)
tk.Button(root, text="Scan QR Code from Image", command=scan_qr,
          font=("Arial", 12), bg="blue", fg="white").pack(pady=10)
tk.Button(root, text="Scan QR Code (Live Camera)", command=scan_qr_live,
          font=("Arial", 12), bg="purple", fg="white").pack(pady=10)
qr_label = tk.Label(root, bg="white")
qr_label.pack(pady=20)
root.mainloop()
